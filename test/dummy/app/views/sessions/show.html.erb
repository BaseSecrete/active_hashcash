<%= javascript_include_tag "hashcash", "data-turbo-track": "reload", defer: true %>

<%= form_tag session_path do |form| %>
  <%= hashcash_hidden_field_tag %>

  <%= label_tag :email %>
  <%= email_field_tag :email %>

  <%= label_tag :password %>
  <%= password_field_tag :password %>

  <%= submit_tag "Send" %>
<% end %>